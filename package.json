{
  "name": "maintenance-center5",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap-cloud-sdk/http-client": "^4.7.0",
    "@sap/cds": "^9",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^2.4",
    "@sap/cds-dk": "^9",
    "cds-plugin-ui5": "^0.17.0",
    "mbt": "^1.2.49",
    "rimraf": "^5.0.5"
  },
  "scripts": {
    "start": "cds-serve",
    "watch-equip": "cds watch --open equip/index.html?sap-ui-xx-viewCache=false --livereload false",
    "undeploy": "cf undeploy maintenance-center5 --delete-services --delete-service-keys --delete-service-brokers",
    "build": "rimraf resources mta_archives && mbt build --mtar archive",
    "deploy": "cf deploy mta_archives/archive.mtar --retries 1",
    "watch-project1": "cds watch --open project1/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "private": true,
  "cds": {
    "requires": {
      "auth": {
        "kind": "mocked",
        "users": {
          "viewer": {
            "password": "viewer",
            "roles": [
              "Viewer"
            ]
          },
          "manager": {
            "password": "manager",
            "roles": [
              "Viewer",
              "Manager"
            ]
          },
          "technician": {
            "password": "technician",
            "roles": [
              "Viewer",
              "Technician"
            ]
          },
          "admin": {
            "password": "admin",
            "roles": [
              "Viewer",
              "Manager",
              "Technician",
              "Admin"
            ]
          },
          "*": false
        }
      },
      "[production]": {
        "auth": "xsuaa",
        "db": "hana"
      },
      "connectivity": true,
      "destinations": true,
      "html5-repo": true,
      "workzone": true,
      "CPIService": {
        "kind": "rest",
        "credentials": {
          "destination": "CPI_DEST"
        }
      },
      "[hybrid]": {
        "db": "hana"
      }
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/equip",
    "app/project1"
  ]
}
